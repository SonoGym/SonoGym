{
    "policy": {
        "type": "act",
        "device": "cuda",
        "use_amp": false,

        "n_obs_steps": 1,
        "n_action_steps": 100,
        "chunk_size": 100,

        "vision_backbone": "resnet18",
        "pretrained_backbone_weights": "ResNet18_Weights.IMAGENET1K_V1",
        "replace_final_stride_with_dilation": false,
        "pre_norm": false,

        "dim_model": 512,
        "n_heads": 8,
        "dim_feedforward": 3200,
        "feedforward_activation": "relu",
        "n_encoder_layers": 4,
        "n_decoder_layers": 1,
        "use_vae": true,
        "latent_dim": 32,
        "n_vae_encoder_layers": 4,
        "temporal_ensemble_coeff": null,
        "dropout": 0.1,
        "kl_weight": 10.0,
        "optimizer_lr": 1e-05,
        "optimizer_weight_decay": 0.0001,
        "optimizer_lr_backbone": 1e-05,

        "normalization_mapping": {
            "STATE": "MEAN_STD",
            "ACTION": "MEAN_STD",
            "ENV": "MIN_MAX"
        },
        "input_features": {
            "observation.state": {
                "type": "STATE",
                "shape": [
                    25
                ]
            },
            "observation.environment_state": {
                "type": "ENV",
                "shape": [
                    1
                ]
            }
        },
        "output_features": {
            "action": {
                "type": "ACTION",
                "shape": [
                    27
                ]
            }
        }
    },
    "seed": 1000,
    "eval": {
        "n_episodes": 50,
        "batch_size": 50,
        "use_async_envs": false
    }
}
